# Copy to .env and edit. docker compose loads .env automatically.

# Raw ingestion dir — what artists upload to (FBX, source OGG, etc.).
# The cooker watches this dir; nginx never reads it directly.
RAW_PATH=/home/narfman0/synty_raw

# Cooked output dir — what nginx serves at /assets/. Created by the cooker
# from sources in RAW_PATH. Safe to nuke and regenerate.
COOKED_PATH=/home/narfman0/synty_cooked

# Host port to expose nginx on (container always listens on 80).
# Default 49200 is in the dynamic range and unlikely to clash with other
# asset/dev servers (8000/8080/3000/5000 etc.).
ASSET_PORT=49200
